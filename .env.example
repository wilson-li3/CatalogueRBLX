# Supabase (required for outfit saving, sharing, and voting)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Roblox (required for 2D avatar rendering)
# Get this from DevTools → Application → Cookies → .ROBLOSECURITY on roblox.com
ROBLOX_COOKIE=_|WARNING:-DO-NOT-SHARE-THIS...(your cookie value)
